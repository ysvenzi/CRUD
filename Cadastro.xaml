<Window x:Class="CRUD.Cadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRUD"
        mc:Ignorable="d"
        Title="orkut - Criar Conta" 
        Height="580" Width="450" 
        ResizeMode="NoResize" 
        WindowStartupLocation="CenterScreen"
        Background="#F4EFEA" FontFamily="Segoe UI">
        
    <Grid>
        <!-- Fundo em Gradiente idêntico ao Login -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F9F6F0" Offset="0.0"/>
                <GradientStop Color="#E6DEC9" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
            
            <!-- Título da Janela de Cadastro -->
            <TextBlock Text="Crie uma conta" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#7B583E" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="2" ShadowDepth="1" Color="#D2B48C" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <!-- Card de Formulário -->
            <Border Background="White" 
                    BorderBrush="#D5C5B5" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="25,25,25,25">
                
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#8B7355" Opacity="0.15"/>
                </Border.Effect>

                <StackPanel>
                    
                    <!-- Campo: Nome -->
                    <Label Content="Nome:" 
                           Foreground="#5A4535" 
                           FontWeight="SemiBold" 
                           Padding="0" 
                           Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNome" 
                             Height="35" 
                             Padding="8,5,8,5" 
                             BorderBrush="#D5C5B5" 
                             BorderThickness="1" 
                             Margin="0,0,0,15" 
                             VerticalContentAlignment="Center"/>
                    
                    <!-- Campo: Username -->
                    <Label Content="Username:" 
                           Foreground="#5A4535" 
                           FontWeight="SemiBold" 
                           Padding="0" 
                           Margin="0,0,0,5"/>
                    <TextBox x:Name="txtUser" 
                             Height="35" 
                             Padding="8,5,8,5" 
                             BorderBrush="#D5C5B5" 
                             BorderThickness="1" 
                             Margin="0,0,0,15" 
                             VerticalContentAlignment="Center"/>
                    
                    <!-- Campo: E-mail -->
                    <Label Content="E-mail:" 
                           Foreground="#5A4535" 
                           FontWeight="SemiBold" 
                           Padding="0" 
                           Margin="0,0,0,5"/>
                    <TextBox x:Name="txtEmail" 
                             Height="35" 
                             Padding="8,5,8,5" 
                             BorderBrush="#D5C5B5" 
                             BorderThickness="1" 
                             Margin="0,0,0,15" 
                             VerticalContentAlignment="Center"/>
                    
                    <!-- Campo: Senha -->
                    <Label Content="Senha:" 
                           Foreground="#5A4535" 
                           FontWeight="SemiBold" 
                           Padding="0" 
                           Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtSenha" 
                                 Height="35" 
                                 Padding="8,5,8,5" 
                                 BorderBrush="#D5C5B5" 
                                 BorderThickness="1" 
                                 Margin="0,0,0,25" 
                                 VerticalContentAlignment="Center"/>
                    
                    <!-- Botão Cadastrar -->
                    <Button x:Name="btnCadastro" 
                            Content="Registre-se" 
                            Height="40" 
                            Background="#7B583E" 
                            Foreground="White" 
                            FontWeight="Bold" 
                            FontSize="14"
                            BorderThickness="0" 
                            Cursor="Hand"
                            Click="BtnCadastrar_OnClick">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#5C402D"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                    
                </StackPanel>
            </Border>
            
            <!-- Rodapé sutil padrão Orkut -->
            <TextBlock Text="© 2004 - 2026 orkut paródia inc." 
                       FontSize="11" 
                       Foreground="#A89482" 
                       HorizontalAlignment="Center" 
                       Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>
