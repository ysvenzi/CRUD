<Window x:Class="CRUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRUD"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="400" Width="400" 
        ResizeMode ="NoResize" 
        WindowStartupLocation="CenterScreen">
        
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Crie uma conta!" FontSize="24" HorizontalAlignment="Center"/>
            
            <Label Content="Nome:" Margin="0 0 0 2"/>
            <TextBox x:Name="txtNome" Height="25" Margin="0 0 0 10" VerticalAlignment="Center"/>
            
            <Label Content="Username:" Margin="0 0 0 2"/>
            <TextBox x:Name="txtUser" Height="25" Margin="0 0 0 10" VerticalAlignment="Center"/>
            
            <Label Content="E-mail:" Margin="0 0 0 2"/>
            <TextBox x:Name="txtEmail" Height="25" Margin="0 0 0 10" VerticalAlignment="Center"/>
            
            <Label Content="Senha:" Margin="0 0 0 2"/>
            <PasswordBox x:Name="txtSenha" Height="25" Margin="0 0 0 10" VerticalAlignment="Center"/>
            
            <Button x:Name="btnCadastro" Margin="0 15 0 0" Width="300" Content="Registre-se" Click="BtnCadastrar_OnClick"/>
            
        </StackPanel>
    </Grid>
</Window>
